@model LaptopStore.Models.Product

<div class="container mt-4">

    <div class="row">

        <!-- Ảnh sản phẩm -->

        <div class="col-lg-5">

            <div class="card shadow border-0">

                <img src="@Model.ImageUrl"
                     class="img-fluid p-4"
                     style="max-height:450px;object-fit:contain;" />

            </div>

        </div>

        <!-- Thông tin -->

        <div class="col-lg-7">

            <h2 class="fw-bold">
                @Model.Name
            </h2>

            <hr />

            @if (Model.SalePrice.HasValue)
            {
                <p class="text-decoration-line-through text-muted fs-5">
                    @Model.Price.ToString("N0") VNĐ
                </p>

                <h2 class="text-danger fw-bold">
                    @Model.SalePrice.Value.ToString("N0") VNĐ
                </h2>

                <span class="badge bg-danger">
                    SALE
                </span>
            }
            else
            {
                <h2 class="text-danger fw-bold">
                    @Model.Price.ToString("N0") VNĐ
                </h2>
            }

            <div class="card mt-4 border-0 bg-light">

                <div class="card-body">

                    <h5 class="mb-3">
                        ⚙️ Thông số kỹ thuật
                    </h5>

                    <table class="table">

                        <tr>
                            <th width="120">CPU</th>
                            <td>@Model.Cpu</td>
                        </tr>

                        <tr>
                            <th>RAM</th>
                            <td>@Model.Ram</td>
                        </tr>

                        <tr>
                            <th>SSD</th>
                            <td>@Model.Ssd</td>
                        </tr>

                    </table>

                </div>

            </div>

            <div class="mt-4">

                <a asp-controller="Cart"
                   asp-action="AddToCart"
                   asp-route-id="@Model.Id"
                   class="btn btn-primary btn-lg">

                    🛒 Thêm vào giỏ hàng

                </a>

                <a asp-controller="Wishlist"
                   asp-action="Add"
                   asp-route-productId="@Model.Id"
                   class="btn btn-outline-danger btn-lg">

                    ❤️ Yêu thích

                </a>

            </div>

        </div>

    </div>

    <!-- Mô tả -->

    <div class="card shadow border-0 mt-5">

        <div class="card-header bg-dark text-white">

            📄 Mô tả sản phẩm

        </div>

        <div class="card-body">

            @Model.Description

        </div>

    </div>

</div>
<h3 class="mt-5 mb-4">
    🔥 Sản phẩm cùng hãng
</h3>

<div class="row">

    @foreach (var item in ViewBag.RelatedProducts)
    {
        <div class="col-md-3">

            <div class="card shadow-sm">

                <img src="@item.ImageUrl"
                     class="card-img-top p-3"
                     style="height:180px;object-fit:contain;" />

                <div class="card-body">

                    <h6>@item.Name</h6>

                    <p class="text-danger fw-bold">
                        @item.Price.ToString("N0") VNĐ
                    </p>

                    <a asp-controller="Product"
                       asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn btn-primary btn-sm">

                        Xem

                    </a>

                </div>

            </div>

        </div>
    }
</div>