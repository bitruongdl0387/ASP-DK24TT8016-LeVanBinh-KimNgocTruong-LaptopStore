@model LaptopStore.Models.Brand

<h2>✏️ Sửa hãng sản phẩm</h2>

<form method="post">

    <input asp-for="Id" type="hidden" />

    <div class="mb-3">
        <label>Tên hãng</label>
        <input asp-for="Name"
               class="form-control" />
    </div>

    <button class="btn btn-primary">
        Cập nhật
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Quay lại
    </a>

</form>