@model List<LaptopStore.Models.Order>

<div class="container mt-4">
    <h2>Quản lý đơn hàng</h2>

    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>Mã đơn</th>
                <th>Mã khách hàng</th>
                <th>Số điện thoại</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Ghi chú</th>
                <th>Ngày đặt</th>
                <th>Chi tiêt</th>
                <th>Cập nhật trạng thái</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>#@item.Id</td>
                    <td>@item.Customer?.FullName</td>
                    <td>@item.Customer?.Phone</td>
                    <td>@item.TotalAmount.ToString("N0") VNĐ</td>
                    <td>
                        @if (item.Status == "Confirmed")
                        {
                            <span class="badge bg-primary">
                                Confirmed
                            </span>
                        }
                        else if (item.Status == "Delivery")
                        {
                            <span class="badge bg-warning">
                                Delivery
                            </span>
                        }
                        else if (item.Status == "Completed")
                        {
                            <span class="badge bg-success">
                                Completed
                            </span>
                        }
                        else if (item.Status == "Cancelled")
                        {
                            <span class="badge bg-danger">
                                Cancelled
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">
                                Pending
                            </span>
                        }
                    </td>
                    <td>@item.Note</td>
                    <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <a asp-action="Detail"
                           asp-route-id="@item.Id"
                           class="btn btn-info btn-sm">
                            Xem chi tiết
                        </a>
                    </td>
                    <td>
                        <div class="btn-group">

                            <a asp-action="UpdateStatus"
                               asp-route-id="@item.Id"
                               asp-route-status="Confirmed"
                               class="btn btn-sm btn-primary">
                                Xác nhận
                            </a>

                            <a asp-action="UpdateStatus"
                               asp-route-id="@item.Id"
                               asp-route-status="Shipping"
                               class="btn btn-sm btn-warning">
                                Giao hàng
                            </a>

                            <a asp-action="UpdateStatus"
                               asp-route-id="@item.Id"
                               asp-route-status="Completed"
                               class="btn btn-sm btn-success">
                                Hoàn thành
                            </a>

                            <a asp-action="UpdateStatus"
                               asp-route-id="@item.Id"
                               asp-route-status="Cancelled"
                               class="btn btn-sm btn-danger">
                                Hủy
                            </a>

                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>