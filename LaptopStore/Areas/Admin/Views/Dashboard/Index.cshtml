<div class="container-fluid">

    <h2 class="mb-4">
        📊 Dashboard Admin
    </h2>

    <div class="row">

        <div class="col-md-3 mb-3">
            <div class="card bg-primary text-white shadow">
                <div class="card-body text-center">
                    <h5>💻 Sản phẩm</h5>
                    <h2>@ViewBag.TotalProducts</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card bg-success text-white shadow">
                <div class="card-body text-center">
                    <h5>📦 Đơn hàng</h5>
                    <h2>@ViewBag.TotalOrders</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card bg-warning shadow">
                <div class="card-body text-center">
                    <h5>👤 Khách hàng</h5>
                    <h2>@ViewBag.TotalCustomers</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card bg-danger text-white shadow">
                <div class="card-body text-center">
                    <h5>💰 Doanh thu</h5>
                    <h5>
                        @(((decimal)ViewBag.TotalRevenue).ToString("N0")) VNĐ
                    </h5>
                </div>
            </div>
        </div>

    </div>

    <div class="row mt-3">

        <div class="col-md-4">

            <div class="card border-warning shadow-sm">

                <div class="card-body text-center">

                    <h5>⏳ Chờ xử lý</h5>

                    <h2>@ViewBag.PendingOrders</h2>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card border-success shadow-sm">

                <div class="card-body text-center">

                    <h5>✅ Hoàn thành</h5>

                    <h2>@ViewBag.CompletedOrders</h2>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card border-danger shadow-sm">

                <div class="card-body text-center">

                    <h5>❌ Hủy đơn</h5>

                    <h2>@ViewBag.CancelledOrders</h2>

                </div>

            </div>

        </div>

    </div>

</div>